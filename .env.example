# Получите токен на https://huggingface.co/settings/tokens (бесплатно)
# Нужен для скачивания моделей при первом запуске
HF_TOKEN=hf_ваш_токен_сюда

# Модель Whisper для транскрибации
# Варианты: tiny, base, small, medium, large-v1, large-v2, large-v3, large-v3-turbo
WHISPER_MODEL=large-v3-turbo

# Папка для данных (транскрибации, TTS файлы, пресеты голосов)
# По умолчанию ./data рядом с docker-compose.yml
# DATA_DIR=./data
